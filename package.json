{
	"name": "vue3-ui-lib-template",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@8.15.1",
	"scripts": {
		"dev": "run-p -l library:watch playground:dev",
		"library:watch": "pnpm --filter \"base-ui\" watch",
		"library:build": "pnpm --filter \"base-ui\" build",
		"library:publish": "pnpm --filter \"base-ui\" publish",
		"playground:dev": "pnpm --filter \"playground\" dev",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"type-check": "pnpm --filter \"*\" type-check"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^2.6.3",
		"@types/node": "^20.x",
		"eslint": "^8.56.0",
		"npm-run-all": "^4.1.5",
		"sass": "^1.98.0",
		"vue": "^3.5.31"
	}
}
